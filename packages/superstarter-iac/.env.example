# Copy to .env.local in this directory and fill in the values.
# `bun run deploy` reads this automatically (Bun auto-loads .env.local
# from the cwd, so you must run deploy from packages/superstarter-iac/).

# Slug of your Vercel team (visible in the Vercel dashboard URL).
VERCEL_TEAM_SLUG=

# Defaults to "superstarter" if unset; only override if your Vercel
# project has a different name.
# VERCEL_PROJECT_NAME=superstarter

# 32+ chars, encrypts secrets in the committed .alchemy/ state files.
# Generate with: openssl rand -base64 48
# Share via password manager — every deployer needs the same value.
ALCHEMY_PASSWORD=
