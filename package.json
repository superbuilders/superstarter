{
	"name": "superstarter",
	"version": "1.0.0",
	"private": false,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun --bun next dev",
		"build": "bun --bun next build",
		"start": "bun --bun next start",
		"lint": "bun --bun biome lint --write --staged --no-errors-on-unmatched && bun run scripts/dev/lint.ts --staged",
		"lint:all": "bun --bun biome lint --write && bun run scripts/dev/lint.ts",
		"style": "bun run scripts/dev/style.ts",
		"format": "bun run scripts/dev/fmt.ts --strip-comments --write && bun --bun biome format --write",
		"typecheck": "bun run scripts/dev/typecheck.ts",
		"knip": "knip",
		"db:generate": "bun --bun run src/db/scripts/drizzle-kit-shim.ts generate",
		"db:migrate": "bun --bun run src/db/scripts/drizzle-kit-shim.ts migrate && bun run db:push:programs",
		"db:push": "bun --bun run src/db/scripts/drizzle-kit-shim.ts push && bun run db:push:programs",
		"db:push:programs": "bun --bun run src/db/scripts/push-programs.ts",
		"db:studio": "bun --bun run src/db/scripts/drizzle-kit-shim.ts studio",
		"db:drop:schema": "bun --bun run src/db/scripts/drop-schema.ts"
	},
	"dependencies": {
		"@aws-sdk/client-secrets-manager": "^3.1037.0",
		"@aws-sdk/rds-signer": "^3.1037.0",
		"@base-ui/react": "^1.4.1",
		"@next/env": "^16.2.4",
		"@superbuilders/errors": "^3.0.2",
		"@superbuilders/limiter": "^0.1.0",
		"@superbuilders/tracing": "^0.1.0",
		"@superbuilders/validate": "^0.3.0",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@vercel/functions": "^3.4.4",
		"@vercel/oidc-aws-credentials-provider": "^3.0.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"lucide-react": "^1.11.0",
		"next": "^16.2.4",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"shadcn": "^4.5.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"workflow": "^4.2.4"
	},
	"devDependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.119",
		"@biomejs/biome": "^2.4.13",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/bun": "^1.3.13",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native": "npm:typescript@^7.0.2",
		"drizzle-kit": "^0.31.10",
		"knip": "^5.88.1",
		"lefthook": "^2.1.6",
		"pino-pretty": "^13.1.3",
		"postcss": "^8.5.12",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3"
	},
	"ct3aMetadata": {
		"initVersion": "7.39.3"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@tailwindcss/oxide",
		"lefthook"
	]
}
