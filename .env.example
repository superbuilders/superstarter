# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.
#
# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.
#
# When adding additional environment variables, the schema in "/src/env.ts"
# should be updated accordingly.

# ===== From the IaC deploy output (packages/superstarter-iac) =====
# Paste these into Vercel project env AND your local .env.

# IAM role assumed by the Vercel runtime via OIDC. Format: arn:aws:iam::<acct>:role/<name>
AWS_ROLE_ARN=

# RDS endpoint (no port, no scheme). Format: <id>.<region>.rds.amazonaws.com
DATABASE_HOST=

# ===== Local-only (do NOT add to Vercel) =====

# Master credentials secret ARN, used by `bun db:push:programs`, `db:migrate`,
# `db:drop:schema`. The Vercel runtime never reads this — it uses RDS IAM auth.
DATABASE_ADMIN_SECRET_ARN=

# Local-Docker fallback for week-1 dev. When set, the db layer skips the AWS
# RDS Signer + Secrets Manager path and uses this connection string for both
# the regular pool (src/db/index.ts) and the admin pool (src/db/admin.ts).
# AWS_ROLE_ARN, DATABASE_HOST, and DATABASE_ADMIN_SECRET_ARN can stay empty
# in this mode. See README.md > "Local Postgres via Docker".
# Default for the bundled docker-compose.yml:
# DATABASE_LOCAL_URL=postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_LOCAL_URL=

# ===== Auth.js =====
# Generate with: openssl rand -base64 32  (or any 32+ char random string)
AUTH_SECRET=
# Google OAuth client (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google for local dev
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ===== LLM providers (server-side only) =====
# Anthropic API key, billing enabled. Used by the generator (Claude Sonnet).
ANTHROPIC_API_KEY=
# OpenAI API key, billing enabled. Used by the validator (GPT-4o) and embeddings.
OPENAI_API_KEY=

# ===== Cron auth =====
# 32+ char random string. Used as Bearer token by Vercel Cron Jobs to call /api/cron/*.
CRON_SECRET=
