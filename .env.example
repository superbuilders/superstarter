# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.
#
# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.
#
# When adding additional environment variables, the schema in "/src/env.ts"
# should be updated accordingly.

# ===== From the IaC deploy output (packages/superstarter-iac) =====
# Paste these into Vercel project env AND your local .env.

# IAM role assumed by the Vercel runtime via OIDC. Format: arn:aws:iam::<acct>:role/<name>
AWS_ROLE_ARN=

# RDS endpoint (no port, no scheme). Format: <id>.<region>.rds.amazonaws.com
DATABASE_HOST=

# ===== Local-only (do NOT add to Vercel) =====

# Master credentials secret ARN, used by `bun db:push:programs`, `db:migrate`,
# `db:drop:schema`. The Vercel runtime never reads this — it uses RDS IAM auth.
DATABASE_ADMIN_SECRET_ARN=

# ===== Clerk authentication =====
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
